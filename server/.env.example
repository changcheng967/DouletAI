# === Currently Configured Providers ===
# NVIDIA NIM — 49 free models (get key: https://build.nvidia.com/)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenCode Zen — 4 free models via OpenRouter
ZEN_API_KEY=
ZEN_BASE_URL=https://opencode.ai/zen/v1

# Arli AI — trial models including Qwen, GLM, Gemma, Mistral (get key: https://arliai.com/)
ARLIAI_API_KEY=
ARLIAI_BASE_URL=https://api.arliai.com/v1

# FreeTheAi — Claude, GPT, Gemini, Grok models (get key: https://freetheai.xyz/)
FREETHEAI_API_KEY=
FREETHEAI_BASE_URL=https://api.freetheai.xyz/v1

# Modal — GLM 5.1 FP8 (get key: https://modal.com/)
MODAL_API_KEY=
MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1

# === Additional Providers (add keys to activate) ===
# Groq — ultra-fast inference, free tier (get key: https://console.groq.com/keys)
GROQ_API_KEY=

# SambaNova — free fast inference (get key: https://cloud.sambanova.ai/)
SAMBANOVA_API_KEY=

# Cerebras — ultra-fast inference, free tier (get key: https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=

# Google Gemini — direct API, generous free tier (get key: https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# OpenRouter — 30+ free models (get key: https://openrouter.ai/)
OPENROUTER_API_KEY=

# GitHub Models — GPT-4.1, o4-mini, Llama, etc. (use GitHub PAT: https://github.com/settings/tokens)
GITHUB_TOKEN=

# Server port
PORT=3001
